# ============================================================
# UGC Creator Squad — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com suas credenciais
# cp .env.example .env
# ============================================================

# Google AI Studio — Gemini API (geração de imagem e vídeo VEO3)
# Obtenha em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Supabase — Banco de dados e Storage
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
